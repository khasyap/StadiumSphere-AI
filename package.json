{
  "name": "stadiumsphere-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise monorepo foundation for StadiumSphere AI.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint && pnpm run ai:lint",
    "format": "prettier --write . && pnpm run ai:format",
    "format:check": "prettier --check . && pnpm run ai:format:check",
    "test": "turbo run test && pnpm run ai:test && pnpm run validate:foundation",
    "typecheck": "turbo run typecheck && pnpm run ai:typecheck",
    "clean": "turbo run clean && pnpm run ai:clean",
    "ai:dev": "uv --directory apps/ai run uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "ai:lint": "uv --directory apps/ai run ruff check app tests",
    "ai:format": "uv --directory apps/ai run ruff format app tests",
    "ai:format:check": "uv --directory apps/ai run ruff format --check app tests",
    "ai:test": "uv --directory apps/ai run pytest",
    "ai:typecheck": "uv --directory apps/ai run mypy app",
    "ai:clean": "uv --directory apps/ai clean",
    "validate:foundation": "node scripts/validate-foundation.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@stadiumsphere/eslint-config": "workspace:*",
    "@stadiumsphere/prettier-config": "workspace:*",
    "@stadiumsphere/tsconfig": "workspace:*",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.5",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,json,yml,yaml,md,css}": "prettier --write",
    "*.{ts,tsx,mts,cts}": "eslint --fix"
  }
}
