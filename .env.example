# Shared local-development configuration. Copy this file to .env before running Docker Compose.
WEB_PORT=5173
API_PORT=3000
AI_PORT=8000
MONGODB_PORT=27017
REDIS_PORT=6379
API_LOG_LEVEL=info
AI_LOG_LEVEL=INFO
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173
SWAGGER_ENABLED=true
VITE_API_BASE_URL=http://localhost:3000/api/v1
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=stadiumsphere
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=optional-local-redis-password
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
