NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=stadiumsphere
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=optional-local-redis-password
JWT_ACCESS_SECRET=replace-with-a-local-secret-of-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_SECRET=replace-with-a-different-local-secret-of-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=604800
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
SWAGGER_ENABLED=true
