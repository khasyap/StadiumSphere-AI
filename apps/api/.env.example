NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=stadiumsphere
