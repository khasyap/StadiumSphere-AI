{
  "name": "@stadiumsphere/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
	"dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:dev": "pnpm run build && pnpm run start",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src test",
    "test": "jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "mongoose": "^8.15.1",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.3",
    "@stadiumsphere/eslint-config": "workspace:*",
    "@stadiumsphere/tsconfig": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.2",
    "jest": "^30.0.4",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
